# AWS Configuration
AWS_REGION=us-east-1

# Database Configuration for AWS RDS
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=wedding_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_SSL=true

# Optional: Connection pool settings
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Application Settings
NODE_ENV=production
SESSION_SECRET=your-session-secret-key-change-this

# AWS SES Configuration
SES_FROM_EMAIL=invitations@yourdomain.com
SES_REPLY_TO_EMAIL=contact@yourdomain.com

# AWS SNS Configuration (optional)
SNS_FROM_NUMBER=YourWedding

# Twilio WhatsApp Configuration (optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_TEMPLATE_SID=your_template_sid

# VPC Configuration (for Lambda functions)
VPC_SECURITY_GROUP_ID=sg-xxxxxxxxx
VPC_SUBNET_ID_1=subnet-xxxxxxxxx
VPC_SUBNET_ID_2=subnet-xxxxxxxxx
